  },
  "commands": [
    {
      "name": "Get-AzStorageAdvancedPlatformMetric",
      "description": "Get the advanced platform metrics rule for the storage account by rule type.",
      "path": "/subscriptions/{subscriptionId}/resourceGroups/{resourceGroupName}/providers/Microsoft.Storage/storageAccounts/{accountName}/advancedPlatformMetrics/{advancedPlatformMetricsRuleType}",
      "help": {
        "learnMore": {
          "url": "https://learn.microsoft.com/powershell/module/az.storage/get-azstorageadvancedplatformmetric"
        },
        "parameterSets": [
          {
            "parameters": [
              "-AccountName <String>",
              "-ResourceGroupName <String>",
              "[-SubscriptionId <String[]>]"
            ]
          }
        ]
      },
      "examples": [
        {
          "description": "Get the advanced platform metrics rule for the storage account by rule type.",
          "parameters": [
            {
              "name": "-AccountName",
              "value": "[Path.accountName]"
            },
            {
              "name": "-ResourceGroupName",
              "value": "[Path.resourceGroupName]"
            },
            {
              "name": "-SubscriptionId",
              "value": "[Path.subscriptionId]"
            }
          ]
        }
      ]
    },
    {
      "name": "Remove-AzStorageAdvancedPlatformMetric",
      "description": "Delete the advanced platform metrics rule for the storage account by rule type.",
      "path": "/subscriptions/{subscriptionId}/resourceGroups/{resourceGroupName}/providers/Microsoft.Storage/storageAccounts/{accountName}/advancedPlatformMetrics/{advancedPlatformMetricsRuleType}",
      "help": {
        "learnMore": {
          "url": "https://learn.microsoft.com/powershell/module/az.storage/remove-azstorageadvancedplatformmetric"
        },
        "parameterSets": [
          {
            "parameters": [
              "-AccountName <String>",
              "-ResourceGroupName <String>",
              "[-SubscriptionId <String>]"
            ]
          }
        ]
      },
      "examples": [
        {
          "description": "Delete the advanced platform metrics rule for the storage account by rule type.",
          "parameters": [
            {
              "name": "-AccountName",
              "value": "[Path.accountName]"
            },
            {
              "name": "-ResourceGroupName",
              "value": "[Path.resourceGroupName]"
            },
            {
              "name": "-SubscriptionId",
              "value": "[Path.subscriptionId]"
            }
          ]
        }
      ]
    }
  ]
