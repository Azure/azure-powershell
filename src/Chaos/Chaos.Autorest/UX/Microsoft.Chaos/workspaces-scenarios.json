{
  "resourceType": "workspaces/scenarios",
  "apiVersion": "2026-05-01-preview",
  "learnMore": {
    "url": "https://learn.microsoft.com/powershell/module/az.chaos"
  },
  "commands": [
    {
      "name": "Get-AzChaosScenario",
      "description": "Get a scenario.",
      "path": "/subscriptions/{subscriptionId}/resourceGroups/{resourceGroupName}/providers/Microsoft.Chaos/workspaces/{workspaceName}/scenarios/{scenarioName}",
      "help": {
        "learnMore": {
          "url": "https://learn.microsoft.com/powershell/module/az.chaos/get-azchaosscenario"
        },
        "parameterSets": [
          {
            "parameters": [
              "-Name <String>",
              "-ResourceGroupName <String>",
              "[-SubscriptionId <String[]>]",
              "-WorkspaceName <String>"
            ]
          }
        ]
      },
      "examples": [
        {
          "description": "Get a scenario.",
          "parameters": [
            {
              "name": "-Name",
              "value": "[Path.scenarioName]"
            },
            {
              "name": "-ResourceGroupName",
              "value": "[Path.resourceGroupName]"
            },
            {
              "name": "-SubscriptionId",
              "value": "[Path.subscriptionId]"
            },
            {
              "name": "-WorkspaceName",
              "value": "[Path.workspaceName]"
            }
          ]
        }
      ]
    },
    {
      "name": "Remove-AzChaosScenario",
      "description": "Delete a scenario.",
      "path": "/subscriptions/{subscriptionId}/resourceGroups/{resourceGroupName}/providers/Microsoft.Chaos/workspaces/{workspaceName}/scenarios/{scenarioName}",
      "help": {
        "learnMore": {
          "url": "https://learn.microsoft.com/powershell/module/az.chaos/remove-azchaosscenario"
        },
        "parameterSets": [
          {
            "parameters": [
              "-Name <String>",
              "-ResourceGroupName <String>",
              "[-SubscriptionId <String>]",
              "-WorkspaceName <String>"
            ]
          }
        ]
      },
      "examples": [
        {
          "description": "Delete a scenario.",
          "parameters": [
            {
              "name": "-Name",
              "value": "[Path.scenarioName]"
            },
            {
              "name": "-ResourceGroupName",
              "value": "[Path.resourceGroupName]"
            },
            {
              "name": "-SubscriptionId",
              "value": "[Path.subscriptionId]"
            },
            {
              "name": "-WorkspaceName",
              "value": "[Path.workspaceName]"
            }
          ]
        }
      ]
    }
  ]
}
