      "path": "/subscriptions/{subscriptionId}/resourceGroups/{resourceGroupName}/providers/Microsoft.Cdn/profiles/{profileName}/deploymentVersions/{versionName}/approve",
      "help": {
        "learnMore": {
          "url": "https://learn.microsoft.com/powershell/module/az.cdn/approve-azcdndeploymentversion"
        },
        "parameterSets": [
          {
            "parameters": [
              "-ProfileName <String>",
              "-ResourceGroupName <String>",
              "[-SubscriptionId <String>]",
              "-VersionName <String>"
            ]
          }
        ]
      },
      "examples": [
        {
          "description": "Approve the deployment of the version",
          "parameters": [
            {
              "name": "-ProfileName",
              "value": "[Path.profileName]"
            },
            {
              "name": "-ResourceGroupName",
              "value": "[Path.resourceGroupName]"
            },
            {
              "name": "-SubscriptionId",
              "value": "[Path.subscriptionId]"
            },
            {
              "name": "-VersionName",
              "value": "[Path.versionName]"
            }
          ]
        }
      ]
    },
    {
      "name": "Get-AzCdnDeploymentVersion",
      "description": "Get an existing DeploymentVersion with the specified version name under the specified subscription, resource group and profile.",
      "path": "/subscriptions/{subscriptionId}/resourceGroups/{resourceGroupName}/providers/Microsoft.Cdn/profiles/{profileName}/deploymentVersions/{versionName}",
      "help": {
        "learnMore": {
          "url": "https://learn.microsoft.com/powershell/module/az.cdn/get-azcdndeploymentversion"
        },
        "parameterSets": [
          {
            "parameters": [
              "-ProfileName <String>",
              "-ResourceGroupName <String>",
              "[-SubscriptionId <String[]>]",
              "-VersionName <String>"
            ]
          }
        ]
      },
      "examples": [
        {
          "description": "Get an existing DeploymentVersion with the specified version name under the specified subscription, resource group and profile.",
          "parameters": [
            {
              "name": "-ProfileName",
              "value": "[Path.profileName]"
            },
            {
              "name": "-ResourceGroupName",
              "value": "[Path.resourceGroupName]"
            },
            {
              "name": "-SubscriptionId",
              "value": "[Path.subscriptionId]"
            },
            {
              "name": "-VersionName",
