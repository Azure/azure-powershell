{
  "resourceType": "webAgents/knowledgeSources",
  "apiVersion": "2025-09-01-preview",
  "learnMore": {
    "url": "https://learn.microsoft.com/powershell/module/az.cdn"
  },
  "commands": [
    {
      "name": "Clear-AzCdnKnowledgeSource",
      "description": "Remove the cache of a knowledge source.",
      "path": "/subscriptions/{subscriptionId}/resourceGroups/{resourceGroupName}/providers/Microsoft.Cdn/webAgents/{webAgentName}/knowledgeSources/{knowledgeSourceName}/purge",
      "help": {
        "learnMore": {
          "url": "https://learn.microsoft.com/powershell/module/az.cdn/clear-azcdnknowledgesource"
        },
        "parameterSets": [
          {
            "parameters": [
              "-Name <String>",
              "-ResourceGroupName <String>",
              "[-SubscriptionId <String>]",
              "-WebAgentName <String>"
            ]
          }
        ]
      },
      "examples": [
        {
          "description": "Remove the cache of a knowledge source.",
          "parameters": [
            {
              "name": "-Name",
              "value": "[Path.knowledgeSourceName]"
            },
            {
              "name": "-ResourceGroupName",
              "value": "[Path.resourceGroupName]"
            },
            {
              "name": "-SubscriptionId",
              "value": "[Path.subscriptionId]"
            },
            {
              "name": "-WebAgentName",
              "value": "[Path.webAgentName]"
            }
          ]
        }
      ]
    },
    {
      "name": "Get-AzCdnKnowledgeSource",
      "description": "Gets a knowledge source with the specified name within a web agent.",
      "path": "/subscriptions/{subscriptionId}/resourceGroups/{resourceGroupName}/providers/Microsoft.Cdn/webAgents/{webAgentName}/knowledgeSources/{knowledgeSourceName}",
      "help": {
        "learnMore": {
          "url": "https://learn.microsoft.com/powershell/module/az.cdn/get-azcdnknowledgesource"
        },
        "parameterSets": [
          {
            "parameters": [
              "-Name <String>",
              "-ResourceGroupName <String>",
              "[-SubscriptionId <String[]>]",
              "-WebAgentName <String>"
            ]
          }
        ]
      },
      "examples": [
        {
          "description": "Gets a knowledge source with the specified name within a web agent.",
          "parameters": [
            {
              "name": "-Name",
              "value": "[Path.knowledgeSourceName]"
            },
            {
              "name": "-ResourceGroupName",
              "value": "[Path.resourceGroupName]"
            },
            {
              "name": "-SubscriptionId",
              "value": "[Path.subscriptionId]"
            },
            {
              "name": "-WebAgentName",
              "value": "[Path.webAgentName]"
            }
          ]
        }
      ]
    },
    {
      "name": "Remove-AzCdnKnowledgeSource",
      "description": "Deletes a knowledge source with the specified name within a web agent.",
      "path": "/subscriptions/{subscriptionId}/resourceGroups/{resourceGroupName}/providers/Microsoft.Cdn/webAgents/{webAgentName}/knowledgeSources/{knowledgeSourceName}",
      "help": {
        "learnMore": {
          "url": "https://learn.microsoft.com/powershell/module/az.cdn/remove-azcdnknowledgesource"
        },
        "parameterSets": [
          {
            "parameters": [
              "-Name <String>",
              "-ResourceGroupName <String>",
              "[-SubscriptionId <String>]",
              "-WebAgentName <String>"
            ]
          }
        ]
      },
      "examples": [
        {
          "description": "Deletes a knowledge source with the specified name within a web agent.",
          "parameters": [
            {
              "name": "-Name",
              "value": "[Path.knowledgeSourceName]"
            },
            {
              "name": "-ResourceGroupName",
              "value": "[Path.resourceGroupName]"
            },
            {
              "name": "-SubscriptionId",
              "value": "[Path.subscriptionId]"
            },
            {
              "name": "-WebAgentName",
              "value": "[Path.webAgentName]"
            }
          ]
        }
      ]
    }
  ]
}
