{
  "resourceType": "bookshelves",
  "apiVersion": "2026-06-01",
  "learnMore": {
    "url": "https://learn.microsoft.com/powershell/module/az.discovery"
  },
  "commands": [
    {
      "name": "Get-AzDiscoveryBookshelf",
      "description": "Get a Bookshelf",
      "path": "/subscriptions/{subscriptionId}/resourceGroups/{resourceGroupName}/providers/Microsoft.Discovery/bookshelves/{bookshelfName}",
      "help": {
        "learnMore": {
          "url": "https://learn.microsoft.com/powershell/module/az.discovery/get-azdiscoverybookshelf"
        },
        "parameterSets": [
          {
            "parameters": [
              "-Name <String>",
              "-ResourceGroupName <String>",
              "[-SubscriptionId <String[]>]"
            ]
          }
        ]
      },
      "examples": [
        {
          "description": "Get a Bookshelf",
          "parameters": [
            {
              "name": "-Name",
              "value": "[Path.bookshelfName]"
            },
            {
              "name": "-ResourceGroupName",
              "value": "[Path.resourceGroupName]"
            },
            {
              "name": "-SubscriptionId",
              "value": "[Path.subscriptionId]"
            }
          ]
        }
      ]
    },
    {
      "name": "Remove-AzDiscoveryBookshelf",
      "description": "Delete a Bookshelf",
      "path": "/subscriptions/{subscriptionId}/resourceGroups/{resourceGroupName}/providers/Microsoft.Discovery/bookshelves/{bookshelfName}",
      "help": {
        "learnMore": {
          "url": "https://learn.microsoft.com/powershell/module/az.discovery/remove-azdiscoverybookshelf"
        },
        "parameterSets": [
          {
            "parameters": [
              "-Name <String>",
              "-ResourceGroupName <String>",
              "[-SubscriptionId <String>]"
            ]
          }
        ]
      },
      "examples": [
        {
          "description": "Delete a Bookshelf",
          "parameters": [
            {
              "name": "-Name",
              "value": "[Path.bookshelfName]"
            },
            {
              "name": "-ResourceGroupName",
              "value": "[Path.resourceGroupName]"
            },
            {
              "name": "-SubscriptionId",
              "value": "[Path.subscriptionId]"
            }
          ]
        }
      ]
    }
  ]
}
