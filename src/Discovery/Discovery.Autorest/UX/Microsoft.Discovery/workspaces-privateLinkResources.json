{
  "resourceType": "workspaces/privateLinkResources",
  "apiVersion": "2026-06-01",
  "learnMore": {
    "url": "https://learn.microsoft.com/powershell/module/az.discovery"
  },
  "commands": [
    {
      "name": "Get-AzDiscoveryWorkspacePrivateLinkResource",
      "description": "Gets the specified private link resource for the workspace.",
      "path": "/subscriptions/{subscriptionId}/resourceGroups/{resourceGroupName}/providers/Microsoft.Discovery/workspaces/{workspaceName}/privateLinkResources/{privateLinkResourceName}",
      "help": {
        "learnMore": {
          "url": "https://learn.microsoft.com/powershell/module/az.discovery/get-azdiscoveryworkspaceprivatelinkresource"
        },
        "parameterSets": [
          {
            "parameters": [
              "-PrivateLinkResourceName <String>",
              "-ResourceGroupName <String>",
              "[-SubscriptionId <String[]>]",
              "-WorkspaceName <String>"
            ]
          }
        ]
      },
      "examples": [
        {
          "description": "Gets the specified private link resource for the workspace.",
          "parameters": [
            {
              "name": "-PrivateLinkResourceName",
              "value": "[Path.privateLinkResourceName]"
            },
            {
              "name": "-ResourceGroupName",
              "value": "[Path.resourceGroupName]"
            },
            {
              "name": "-SubscriptionId",
              "value": "[Path.subscriptionId]"
            },
            {
              "name": "-WorkspaceName",
              "value": "[Path.workspaceName]"
            }
          ]
        }
      ]
    }
  ]
}
