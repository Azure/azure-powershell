  "learnMore": {
    "url": "https://learn.microsoft.com/powershell/module/az.discovery"
  },
  "commands": [
    {
      "name": "Get-AzDiscoveryStorageAsset",
      "description": "Get a StorageAsset",
      "path": "/subscriptions/{subscriptionId}/resourceGroups/{resourceGroupName}/providers/Microsoft.Discovery/storageContainers/{storageContainerName}/storageAssets/{storageAssetName}",
      "help": {
        "learnMore": {
          "url": "https://learn.microsoft.com/powershell/module/az.discovery/get-azdiscoverystorageasset"
        },
        "parameterSets": [
          {
            "parameters": [
              "-Name <String>",
              "-ResourceGroupName <String>",
              "-StorageContainerName <String>",
              "[-SubscriptionId <String[]>]"
            ]
          }
        ]
      },
      "examples": [
        {
          "description": "Get a StorageAsset",
          "parameters": [
            {
              "name": "-Name",
              "value": "[Path.storageAssetName]"
            },
            {
              "name": "-ResourceGroupName",
              "value": "[Path.resourceGroupName]"
            },
            {
              "name": "-StorageContainerName",
              "value": "[Path.storageContainerName]"
            },
            {
              "name": "-SubscriptionId",
              "value": "[Path.subscriptionId]"
            }
          ]
        }
      ]
    },
    {
      "name": "Remove-AzDiscoveryStorageAsset",
      "description": "Delete a StorageAsset",
      "path": "/subscriptions/{subscriptionId}/resourceGroups/{resourceGroupName}/providers/Microsoft.Discovery/storageContainers/{storageContainerName}/storageAssets/{storageAssetName}",
      "help": {
        "learnMore": {
          "url": "https://learn.microsoft.com/powershell/module/az.discovery/remove-azdiscoverystorageasset"
        },
        "parameterSets": [
          {
            "parameters": [
              "-Name <String>",
              "-ResourceGroupName <String>",
              "-StorageContainerName <String>",
              "[-SubscriptionId <String>]"
            ]
          }
        ]
      },
      "examples": [
        {
          "description": "Delete a StorageAsset",
          "parameters": [
            {
              "name": "-Name",
              "value": "[Path.storageAssetName]"
            },
            {
              "name": "-ResourceGroupName",
              "value": "[Path.resourceGroupName]"
            },
            {
              "name": "-StorageContainerName",
              "value": "[Path.storageContainerName]"
            },
            {
              "name": "-SubscriptionId",
              "value": "[Path.subscriptionId]"
            }
          ]
        }
      ]
    }
  ]
