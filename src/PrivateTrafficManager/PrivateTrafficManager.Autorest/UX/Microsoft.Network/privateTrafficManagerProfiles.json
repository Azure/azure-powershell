      "help": {
        "learnMore": {
          "url": "https://learn.microsoft.com/powershell/module/az.privatetrafficmanager/get-azprivatetrafficmanagerprofile"
        },
        "parameterSets": [
          {
            "parameters": [
              "-PrivateTrafficManagerProfileName <String>",
              "-ResourceGroupName <String>",
              "[-SubscriptionId <String[]>]"
            ]
          }
        ]
      },
      "examples": [
        {
          "description": "Gets a Private Traffic Manager profile.",
          "parameters": [
            {
              "name": "-PrivateTrafficManagerProfileName",
              "value": "[Path.privateTrafficManagerProfileName]"
            },
            {
              "name": "-ResourceGroupName",
              "value": "[Path.resourceGroupName]"
