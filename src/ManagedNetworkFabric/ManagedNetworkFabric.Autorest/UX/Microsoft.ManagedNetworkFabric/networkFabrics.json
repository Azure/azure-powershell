              "-ResourceGroupName <String>",
              "[-SubscriptionId <String>]"
            ]
          }
        ]
      },
      "examples": [
        {
          "description": "resync the Terminal Server and all Network Devices to use the latest passwords. Does not generate new passwords.\\n\\nAllows devices to be brought back in sync after a partially successful password rotation.",
          "parameters": [
            {
              "name": "-NetworkFabricName",
              "value": "[Path.networkFabricName]"
            },
            {
              "name": "-ResourceGroupName",
              "value": "[Path.resourceGroupName]"
            },
            {
              "name": "-SubscriptionId",
              "value": "[Path.subscriptionId]"
