    {
      "name": "Invoke-AzNetworkFabricRotateNetworkFabricCertificate",
      "description": "Rotate new certificates, then rotate the Network Devices to use the new certificates.\nNote that disabled devices cannot be updated and must be resynchronized with the new certificates once they are enabled.",
      "path": "/subscriptions/{subscriptionId}/resourceGroups/{resourceGroupName}/providers/Microsoft.ManagedNetworkFabric/networkFabrics/{networkFabricName}/rotateCertificates",
      "help": {
        "learnMore": {
          "url": "https://learn.microsoft.com/powershell/module/az.managednetworkfabric/invoke-aznetworkfabricrotatenetworkfabriccertificate"
        },
        "parameterSets": [
          {
            "parameters": [
              "-NetworkFabricName <String>",
              "-ResourceGroupName <String>",
              "[-SubscriptionId <String>]"
            ]
          }
        ]
      },
      "examples": [
        {
          "description": "rotate new certificates, then rotate the Network Devices to use the new certificates. Note that disabled devices cannot be updated and must be resynchronized with the new certificates once they are enabled.",
          "parameters": [
            {
              "name": "-NetworkFabricName",
              "value": "[Path.networkFabricName]"
            },
            {
              "name": "-ResourceGroupName",
              "value": "[Path.resourceGroupName]"
            },
            {
              "name": "-SubscriptionId",
              "value": "[Path.subscriptionId]"
            }
          ]
        }
      ]
    },
    {
      "name": "Invoke-AzNetworkFabricRotateNetworkFabricPassword",
      "description": "Rotate new passwords, then rotate the Terminal Server and Network Devices to use the new passwords.\\n\\nNote that disabled devices cannot be updated and must be resynchronized with the new passwords once they are enabled.\\n\\nFails if any of the devices could not be updated with the new password.\\nFailed devices should be resynchronized with the new passwords once possible.",
      "path": "/subscriptions/{subscriptionId}/resourceGroups/{resourceGroupName}/providers/Microsoft.ManagedNetworkFabric/networkFabrics/{networkFabricName}/rotatePasswords",
      "help": {
        "learnMore": {
          "url": "https://learn.microsoft.com/powershell/module/az.managednetworkfabric/invoke-aznetworkfabricrotatenetworkfabricpassword"
        },
        "parameterSets": [
          {
            "parameters": [
              "-NetworkFabricName <String>",
              "-ResourceGroupName <String>",
              "[-SubscriptionId <String>]"
            ]
          }
        ]
      },
      "examples": [
        {
          "description": "rotate new passwords, then rotate the Terminal Server and Network Devices to use the new passwords.\\n\\nNote that disabled devices cannot be updated and must be resynchronized with the new passwords once they are enabled.\\n\\nFails if any of the devices could not be updated with the new password.\\nFailed devices should be resynchronized with the new passwords once possible.",
          "parameters": [
            {
              "name": "-NetworkFabricName",
              "value": "[Path.networkFabricName]"
            },
            {
              "name": "-ResourceGroupName",
              "value": "[Path.resourceGroupName]"
            },
            {
              "name": "-SubscriptionId",
              "value": "[Path.subscriptionId]"
            }
          ]
        }
      ]
