{
  "resourceType": "networkBootstrapDevices",
  "apiVersion": "2025-07-15",
  "learnMore": {
    "url": "https://learn.microsoft.com/powershell/module/az.managednetworkfabric"
  },
  "commands": [
    {
      "name": "Get-AzNetworkFabricNetworkBootstrapDevice",
      "description": "Gets a Network Bootstrap Device resource details.",
      "path": "/subscriptions/{subscriptionId}/resourceGroups/{resourceGroupName}/providers/Microsoft.ManagedNetworkFabric/networkBootstrapDevices/{networkBootstrapDeviceName}",
      "help": {
        "learnMore": {
          "url": "https://learn.microsoft.com/powershell/module/az.managednetworkfabric/get-aznetworkfabricnetworkbootstrapdevice"
        },
        "parameterSets": [
          {
            "parameters": [
              "-Name <String>",
              "-ResourceGroupName <String>",
              "[-SubscriptionId <String[]>]"
            ]
          }
        ]
      },
      "examples": [
        {
          "description": "Gets a Network Bootstrap Device resource details.",
          "parameters": [
            {
              "name": "-Name",
              "value": "[Path.networkBootstrapDeviceName]"
            },
            {
              "name": "-ResourceGroupName",
              "value": "[Path.resourceGroupName]"
            },
            {
              "name": "-SubscriptionId",
              "value": "[Path.subscriptionId]"
            }
          ]
        }
      ]
    },
    {
      "name": "Invoke-AzNetworkFabricResyncNetworkBootstrapDevicePassword",
      "description": "Resync the Network Bootstrap Device to use the latest passwords.\nDoes not generate new passwords.\nAllows network bootstrap devices missed during a previous password rotation to be brought back into sync.",
      "path": "/subscriptions/{subscriptionId}/resourceGroups/{resourceGroupName}/providers/Microsoft.ManagedNetworkFabric/networkBootstrapDevices/{networkBootstrapDeviceName}/resyncPasswords",
      "help": {
        "learnMore": {
          "url": "https://learn.microsoft.com/powershell/module/az.managednetworkfabric/invoke-aznetworkfabricresyncnetworkbootstrapdevicepassword"
        },
        "parameterSets": [
          {
            "parameters": [
              "-NetworkBootstrapDeviceName <String>",
              "-ResourceGroupName <String>",
              "[-SubscriptionId <String>]"
            ]
          }
        ]
      },
      "examples": [
        {
          "description": "resync the Network Bootstrap Device to use the latest passwords. Does not generate new passwords. Allows network bootstrap devices missed during a previous password rotation to be brought back into sync.",
          "parameters": [
            {
              "name": "-NetworkBootstrapDeviceName",
              "value": "[Path.networkBootstrapDeviceName]"
            },
            {
              "name": "-ResourceGroupName",
              "value": "[Path.resourceGroupName]"
            },
            {
              "name": "-SubscriptionId",
              "value": "[Path.subscriptionId]"
            }
          ]
        }
      ]
    },
    {
      "name": "Remove-AzNetworkFabricNetworkBootstrapDevice",
