{
  "resourceType": "networkDevices",
  "apiVersion": "2025-07-15",
  "learnMore": {
    "url": "https://learn.microsoft.com/powershell/module/az.managednetworkfabric"
  },
  "commands": [
    {
      "name": "Get-AzNetworkFabricDevice",
      "description": "Gets the Network Device resource details.",
      "path": "/subscriptions/{subscriptionId}/resourceGroups/{resourceGroupName}/providers/Microsoft.ManagedNetworkFabric/networkDevices/{networkDeviceName}",
      "help": {
        "learnMore": {
          "url": "https://learn.microsoft.com/powershell/module/az.managednetworkfabric/get-aznetworkfabricdevice"
        },
        "parameterSets": [
          {
            "parameters": [
              "-Name <String>",
              "-ResourceGroupName <String>",
              "[-SubscriptionId <String[]>]"
            ]
          }
        ]
      },
      "examples": [
        {
          "description": "Gets the Network Device resource details.",
          "parameters": [
            {
              "name": "-Name",
              "value": "[Path.networkDeviceName]"
            },
            {
              "name": "-ResourceGroupName",
              "value": "[Path.resourceGroupName]"
            },
            {
              "name": "-SubscriptionId",
              "value": "[Path.subscriptionId]"
            }
          ]
        }
      ]
    },
    {
      "name": "Invoke-AzNetworkFabricResyncNetworkDeviceCertificate",
      "description": "Resync the Network Device to use the latest certificates.\nDoes not generate new certificates.\nAllows network devices missed during a previous certificate rotation to be brought back into sync.",
      "path": "/subscriptions/{subscriptionId}/resourceGroups/{resourceGroupName}/providers/Microsoft.ManagedNetworkFabric/networkDevices/{networkDeviceName}/resyncCertificates",
      "help": {
        "learnMore": {
          "url": "https://learn.microsoft.com/powershell/module/az.managednetworkfabric/invoke-aznetworkfabricresyncnetworkdevicecertificate"
        },
        "parameterSets": [
          {
            "parameters": [
              "-NetworkDeviceName <String>",
              "-ResourceGroupName <String>",
              "[-SubscriptionId <String>]"
            ]
          }
        ]
      },
      "examples": [
        {
          "description": "resync the Network Device to use the latest certificates. Does not generate new certificates. Allows network devices missed during a previous certificate rotation to be brought back into sync.",
          "parameters": [
            {
              "name": "-NetworkDeviceName",
              "value": "[Path.networkDeviceName]"
            },
            {
              "name": "-ResourceGroupName",
              "value": "[Path.resourceGroupName]"
            },
            {
              "name": "-SubscriptionId",
              "value": "[Path.subscriptionId]"
            }
          ]
        }
      ]
    },
    {
      "name": "Invoke-AzNetworkFabricResyncNetworkDevicePassword",
      "description": "Resync the Network Device to use the latest passwords.\nDoes not generate new passwords.\nAllows network devices missed during a previous password rotation to be brought back into sync.",
      "path": "/subscriptions/{subscriptionId}/resourceGroups/{resourceGroupName}/providers/Microsoft.ManagedNetworkFabric/networkDevices/{networkDeviceName}/resyncPasswords",
      "help": {
        "learnMore": {
          "url": "https://learn.microsoft.com/powershell/module/az.managednetworkfabric/invoke-aznetworkfabricresyncnetworkdevicepassword"
        },
        "parameterSets": [
          {
            "parameters": [
              "-NetworkDeviceName <String>",
              "-ResourceGroupName <String>",
              "[-SubscriptionId <String>]"
            ]
          }
        ]
      },
      "examples": [
        {
          "description": "resync the Network Device to use the latest passwords. Does not generate new passwords. Allows network devices missed during a previous password rotation to be brought back into sync.",
          "parameters": [
            {
              "name": "-NetworkDeviceName",
              "value": "[Path.networkDeviceName]"
            },
            {
              "name": "-ResourceGroupName",
              "value": "[Path.resourceGroupName]"
            },
            {
              "name": "-SubscriptionId",
              "value": "[Path.subscriptionId]"
            }
          ]
        }
      ]
    }
  ]
}
