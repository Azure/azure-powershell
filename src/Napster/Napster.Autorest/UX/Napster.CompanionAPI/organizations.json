        },
        "parameterSets": [
          {
            "parameters": [
              "-Name <String>",
              "-ResourceGroupName <String>",
              "[-SubscriptionId <String[]>]"
            ]
          }
        ]
      },
      "examples": [
        {
          "description": "Get a OrganizationResource",
          "parameters": [
            {
              "name": "-Name",
              "value": "[Path.organizationname]"
